0068   1505           00198         bsf             STROBE_LCD                      ;make STROBE '1' to strobe data into 4094 ...
0069   1105           00199         bcf             STROBE_LCD                      ;... and make STROBE '0' again
006A   3002           00200         movlw   D'2'                            ;LCD-module needs 8x5=40 us processing time
006B   216F           00201         call    WAIT_5us
006C   0008           00202         return
