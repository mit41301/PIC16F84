                      00181 
005A                  00182 LCD_WRITE_HALF
005A   39F0           00183         andlw   B'11110000'                     ;select only the first 4 bits
005B   0091           00184         movwf   BYTE                            ;store them in BYTE
005C   0814           00185         movf    LCD_BYTE,0                      ;get LCD_BYTE for the right 4 bits
005D   0491           00186         iorwf   BYTE,1                          ;merge and restore in BYTE
005E   3008           00187         movlw   D'8'                            ;write D7-D0 to 4094 ...
005F   008F           00188         movwf   BIT                                     ;... and keep bit-counter in BIT
0060                  00189 lcd_write_half_1
0060   1085           00190         bcf             DATA_LCD                        ;make DATA-line '0' ...
0061   1B91           00191         btfsc   BYTE,7                          ;... but if leftmost bit='1' ...
