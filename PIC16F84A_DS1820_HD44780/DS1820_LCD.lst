0055                  00175 LCD_WRITE_BYTE                                  ;writes 8 bits from workspace with given RS/BL
0055   0095           00176         movwf   MEM_1                           ;keep 2nd half of databyte stored
0056   205A           00177         call    LCD_WRITE_HALF          ;send 1st half of databyte (bit 7-4)
0057   0E15           00178         swapf   MEM_1,0                         ;get back 2nd half of databyte
